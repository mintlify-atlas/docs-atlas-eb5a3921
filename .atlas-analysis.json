  "publicApiSurface": [
    "POST /api/leads - Create new lead",
    "GET /api/leads - List leads",
    "PUT /api/leads/{id} - Update lead",
    "POST /api/leads/assign - Assign lead to user",
    "POST /api/interactions - Create interaction",
